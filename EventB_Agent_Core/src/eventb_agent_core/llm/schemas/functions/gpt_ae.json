{
	"type": "function",
	"name": "addAbstractExpression",
	"description": "Add an abstract expression to assist proving. It doesn't unfold any logical formula, only call this if the current expressions are too complicated and it's necessary to add some simplifications.",
	"strict": true,
	"parameters": {
		"type": "object",
		"$defs": {
			"expression": {
				"type": "string"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_expression": {
				"type": "object",
				"required": [
					"label_name",
					"expression"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"expression": {
						"$ref": "#/$defs/expression"
					}
				},
				"additionalProperties": false
			}
		},
		"properties": {
			"expression": {
				"$ref": "#/$defs/labeled_expression"
			}
		},
		"additionalProperties": false,
		"required": [
			"expression"
		]
	}
}