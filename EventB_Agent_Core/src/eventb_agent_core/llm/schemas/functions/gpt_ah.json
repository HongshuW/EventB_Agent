{
	"type": "function",
	"name": "addHypothesesToContext",
	"description": "Add hypothesis to the context.",
	"strict": true,
	"parameters": {
		"type": "object",
		"$defs": {
			"predicate": {
				"type": "string"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_predicate": {
				"type": "object",
				"required": [
					"label_name",
					"predicate"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"predicate": {
						"$ref": "#/$defs/predicate"
					}
				},
				"additionalProperties": false
			}
		},
		"properties": {
			"hypothesis": {
				"$ref": "#/$defs/labeled_predicate"
			},
			"instantiations": {
				"type": "array",
				"items": {
					"$ref": "#/$defs/identifier"
				},
				"description": "If the added hypothesis is a universal predicate or an existential predicate, specify the instantiations."
			}
		},
		"additionalProperties": false,
		"required": [
			"hypothesis",
			"instantiations"
		]
	}
}