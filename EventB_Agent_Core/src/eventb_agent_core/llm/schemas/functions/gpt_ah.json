{
	"type": "function",
	"name": "addHypothesesToContext",
	"description": "Add hypothesis as axiom in the context. Use this function when a standard fact that is not recognized by Event-B should be added. ***The hypothesis should be a universal (`\\forall`) or existential (`\\exists`) predicate.***",
	"strict": true,
	"parameters": {
		"type": "object",
		"$defs": {
			"predicate": {
				"type": "string"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_predicate": {
				"type": "object",
				"required": [
					"label_name",
					"predicate"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"predicate": {
						"$ref": "#/$defs/predicate"
					}
				},
				"additionalProperties": false
			}
		},
		"properties": {
			"node_id": {
				"type": "integer",
				"description": "ID of the node in the proof tree to apply this function on."
			},
			"goal": {
				"type": "string",
				"description": "Goal of the selected string."
			},
			"similar_hypothesis": {
				"type": "string",
				"description": "The hypothesis in the node that is the most similar to the goal."
			},
			"hypothesis": {
				"$ref": "#/$defs/labeled_predicate"
			},
			"instantiations": {
				"type": "array",
				"items": {
					"$ref": "#/$defs/identifier"
				}
			}
		},
		"additionalProperties": false,
		"required": [
			"node_id",
			"goal",
			"similar_hypothesis",
			"hypothesis",
			"instantiations"
		]
	}
}