{
	"type": "function",
	"name": "caseDistinctionBySplittingEvent",
	"description": "Split an event into multiple by adding conditions as guards. Call this function when one event is not enough to model the scenario and case distinction is required.",
	"strict": true,
	"parameters": {
		"type": "object",
		"$defs": {
			"predicate": {
				"type": "string"
			},
			"assignment": {
				"type": "string",
				"pattern": "^.*:=.*$"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_predicate": {
				"type": "object",
				"required": [
					"label_name",
					"predicate"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"predicate": {
						"$ref": "#/$defs/predicate"
					}
				},
				"additionalProperties": false
			},
			"labeled_assignment": {
				"type": "object",
				"required": [
					"label_name",
					"assignment"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"assignment": {
						"$ref": "#/$defs/assignment"
					}
				},
				"additionalProperties": false
			},
			"event": {
				"type": "object",
				"required": [
					"event_name",
					"REFINES",
					"ANY",
					"WHERE",
					"WITH",
					"THEN"
				],
				"properties": {
					"event_name": {
						"$ref": "#/$defs/identifier"
					},
					"REFINES": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"ANY": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"WHERE": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_predicate"
						}
					},
					"WITH": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_predicate"
						}
					},
					"THEN": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_assignment"
						}
					}
				},
				"additionalProperties": false
			}
		},
		"properties": {
			"node_id": {
				"type": "integer",
				"description": "ID of the node in the proof tree to apply this function on."
			},
			"event_name": {
				"type": "string",
				"description": "Name of the original event to split."
			},
			"new_events": {
				"type": "array",
				"description": "New events. Include complete information.",
				"items": {
					"$ref": "#/$defs/event"
				}
			}
		},
		"additionalProperties": false,
		"required": [
			"node_id",
			"event_name",
			"new_events"
		]
	}
}