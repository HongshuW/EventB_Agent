{
	"type": "function",
	"name": "strengthenInvariant",
	"description": "Add an invariant to accomplish the missing hypothesis revealed in proofs.",
	"strict": true,
	"parameters": {
		"type": "object",
		"$defs": {
			"predicate": {
				"type": "string"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_predicate": {
				"type": "object",
				"required": [
					"label_name",
					"predicate"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"predicate": {
						"$ref": "#/$defs/predicate"
					}
				},
				"additionalProperties": false
			}
		},
		"properties": {
			"node_id": {
				"type": "integer",
				"description": "ID of the node in the proof tree to apply this function on."
			},
			"invariant": {
				"$ref": "#/$defs/labeled_predicate"
			}
		},
		"additionalProperties": false,
		"required": [
			"node_id",
			"invariant"
		]
	}
}