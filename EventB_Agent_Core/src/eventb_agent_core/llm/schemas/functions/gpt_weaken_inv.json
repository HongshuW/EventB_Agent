{
	"type": "function",
	"name": "weakenInvariant",
	"description": "Weaken an invariant of the machine.",
	"strict": true,
	"parameters": {
		"type": "object",
		"$defs": {
			"predicate": {
				"type": "string"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_predicate": {
				"type": "object",
				"required": [
					"label_name",
					"predicate"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"predicate": {
						"$ref": "#/$defs/predicate"
					}
				},
				"additionalProperties": false
			}
		},
		"properties": {
			"invariant": {
				"$ref": "#/$defs/labeled_predicate"
			},
			"event_name": {
				"type": "string",
				"description": "Name of the event to be modified."
			}
		},
		"additionalProperties": false,
		"required": [
			"invariant",
			"event_name"
		]
	}
}