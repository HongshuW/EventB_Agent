{
	"type": "json_schema",
	"name": "ah_schema",
	"strict": true,
	"schema": {
		"type": "object",
		"$defs": {
			"predicate": {
				"type": "string"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_predicate": {
				"type": "object",
				"required": [
					"label_name",
					"predicate"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"predicate": {
						"$ref": "#/$defs/predicate"
					}
				},
				"additionalProperties": false
			}
		},
		"properties": {
			"explanation": {
				"type": "string"
			},
			"modification": {
				"type": "array",
				"items": {
					"$ref": "#/$defs/labeled_predicate"
				}
			}
		},
		"required": [
			"explanation",
			"modification"
		],
		"additionalProperties": false
	}
}