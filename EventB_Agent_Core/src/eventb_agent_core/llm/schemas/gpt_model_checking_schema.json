{
	"type": "json_schema",
	"name": "model_checking_bound",
	"strict": true,
	"schema": {
		"type": "object",
		"properties": {
			"parameters": {
				"type": "array",
				"description": "Array of parameters specific to the model.",
				"items": {
					"type": "string",
					"pattern": "^.*([<>=]).*$"
				}
			}
		},
		"additionalProperties": false,
		"required": [
			"parameters"
		]
	}
}