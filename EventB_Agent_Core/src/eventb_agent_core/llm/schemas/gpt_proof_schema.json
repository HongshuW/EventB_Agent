{
	"type": "json_schema",
	"name": "proof_schema",
	"strict": true,
	"schema": {
		"type": "object",
		"$defs": {
			"predicate": {
				"type": "string"
			},
			"expression": {
				"type": "string"
			},
			"assignment": {
				"type": "string",
				"pattern": "^.*:=.*$"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_predicate": {
				"type": "object",
				"required": [
					"label_name",
					"predicate"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"predicate": {
						"$ref": "#/$defs/predicate"
					}
				},
				"additionalProperties": false
			},
			"labeled_expression": {
				"type": "object",
				"required": [
					"label_name",
					"expression"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"expression": {
						"$ref": "#/$defs/expression"
					}
				},
				"additionalProperties": false
			},
			"labeled_assignment": {
				"type": "object",
				"required": [
					"label_name",
					"assignment"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"assignment": {
						"$ref": "#/$defs/assignment"
					}
				},
				"additionalProperties": false
			},
			"event": {
				"type": "object",
				"required": [
					"event_name",
					"REFINES",
					"ANY",
					"WHERE",
					"WITH",
					"THEN"
				],
				"properties": {
					"event_name": {
						"$ref": "#/$defs/identifier"
					},
					"REFINES": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"ANY": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"WHERE": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_predicate"
						}
					},
					"WITH": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_predicate"
						}
					},
					"THEN": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_assignment"
						}
					}
				},
				"additionalProperties": false
			}
		},
		"properties": {
			"explanation": {
				"type": "string"
			},
			"modification": {
				"anyOf": [
					{
						"type": "object",
						"required": [
							"context"
						],
						"properties": {
							"context": {
								"type": "array",
								"items": {
									"$ref": "#/$defs/labeled_predicate"
								}
							}
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": [
							"machine"
						],
						"properties": {
							"machine": {
								"type": "array",
								"items": {
									"anyOf": [
										{
											"$ref": "#/$defs/labeled_predicate"
										},
										{
											"$ref": "#/$defs/event"
										}
									]
								}
							}
						},
						"additionalProperties": false
					}
				]
			}
		},
		"required": [
			"explanation",
			"modification"
		],
		"additionalProperties": false
	}
}