{
	"type": "json_schema",
	"name": "eventb_schema",
	"strict": true,
	"schema": {
		"type": "object",
		"$defs": {
			"comments": {
				"type": "string"
			},
			"predicate": {
				"type": "string"
			},
			"expression": {
				"type": "string"
			},
			"assignment": {
				"type": "string",
				"pattern": "^.*:=.*$"
			},
			"identifier": {
				"type": "string",
				"pattern": "^[a-zA-Z][a-zA-Z_0-9]*$"
			},
			"labeled_predicate": {
				"type": "object",
				"required": [
					"label_name",
					"predicate",
					"comments"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"predicate": {
						"$ref": "#/$defs/predicate"
					},
					"comments": {
						"$ref": "#/$defs/comments"
					}
				},
				"additionalProperties": false
			},
			"labeled_expression": {
				"type": "object",
				"required": [
					"label_name",
					"expression",
					"comments"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"expression": {
						"$ref": "#/$defs/expression"
					},
					"comments": {
						"$ref": "#/$defs/comments"
					}
				},
				"additionalProperties": false
			},
			"labeled_assignment": {
				"type": "object",
				"required": [
					"label_name",
					"assignment",
					"comments"
				],
				"properties": {
					"label_name": {
						"$ref": "#/$defs/identifier"
					},
					"assignment": {
						"$ref": "#/$defs/assignment"
					},
					"comments": {
						"$ref": "#/$defs/comments"
					}
				},
				"additionalProperties": false
			},
			"event": {
				"type": "object",
				"required": [
					"event_name",
					"ANY",
					"WHERE",
					"WITH",
					"THEN"
				],
				"properties": {
					"event_name": {
						"$ref": "#/$defs/identifier"
					},
					"ANY": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"WHERE": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_predicate"
						}
					},
					"WITH": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_predicate"
						}
					},
					"THEN": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_assignment"
						}
					}
				},
				"additionalProperties": false
			}
		},
		"required": [
			"context",
			"machine"
		],
		"properties": {
			"context": {
				"type": "object",
				"required": [
					"CONTEXT",
					"SETS",
					"CONSTANTS",
					"AXIOMS"
				],
				"properties": {
					"CONTEXT": {
						"$ref": "#/$defs/identifier"
					},
					"SETS": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"CONSTANTS": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"AXIOMS": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_predicate"
						}
					}
				},
				"additionalProperties": false
			},
			"machine": {
				"type": "object",
				"required": [
					"MACHINE",
					"SEES",
					"VARIABLES",
					"INVARIANTS",
					"VARIANTS",
					"EVENTS"
				],
				"properties": {
					"MACHINE": {
						"$ref": "#/$defs/identifier"
					},
					"SEES": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"VARIABLES": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/identifier"
						}
					},
					"INVARIANTS": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_predicate"
						}
					},
					"VARIANTS": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/labeled_expression"
						}
					},
					"EVENTS": {
						"type": "array",
						"items": {
							"$ref": "#/$defs/event"
						},
						"minItems": 1
					}
				},
				"additionalProperties": false
			}
		},
		"additionalProperties": false
	}
}