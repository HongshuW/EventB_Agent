<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.perspectives">
      <perspective
            class="eventb_agent_ui.EventBAgentPerspective"
            icon="icons/bot.png"
            id="EventB_Agent_UI.perspective"
            name="Event-B Agent">
      </perspective>
   </extension>
   <extension
         point="org.eclipse.ui.perspectiveExtensions">
      <perspectiveExtension
            targetID="EventB_Agent_UI.perspective">
         <view
               id="org.eventb.ui.symboltable.view"
               minimized="false"
               ratio="0.7"
               relationship="right"
               relative="org.eventb.ui.views.RodinProblemView">
         </view>
         <viewShortcut
               id="org.eventb.ui.symboltable.view">
         </viewShortcut>
      </perspectiveExtension>
   </extension>
   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            class="eventb_agent_ui.preference.EventBAgentPreference"
            id="EventB_Agent_UI.preference"
            name="Event-B Agent Preference">
      </page>
   </extension>
   <extension
         point="org.eclipse.ui.newWizards">
      <category
            id="EventB_Agent_UI.category"
            name="Event-B Agent Category">
      </category>
      <wizard
            category="EventB_Agent_UI.category"
            class="eventb_agent_ui.popups.NewModelWizard"
            icon="icons/bot.png"
            id="EventB_Agent_UI.wizards.CreateMachine"
            name="Event-B Agent: Context and Machine Synthesis">
      </wizard>
   </extension>
   <extension
         point="org.eclipse.ui.navigator.navigatorContent">
      <navigatorContent
            id="EventB_Agent_UI.navigatorContent"
            name="Event-B Model Synthesis">
         <commonWizard
               type="import"
               wizardId="EventB_Agent_UI.wizards.CreateMachine">
            <enablement></enablement>
         </commonWizard>
         <triggerPoints>
            <triggerPoint pattern="*"/>
         </triggerPoints>
      </navigatorContent>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="EventB_Agent_UI.agentProverCommand"
            name="Agent Prover">
      </command>
      <command
            id="EventB_Agent_UI.newModelCommand"
            name="Event-B Model Synthesis">
      </command>
      <command
            id="EventB_Agent_UI.evaluate"
            name="Evaluation">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="eventb_agent_ui.handlers.AgentProverHandler"
            commandId="EventB_Agent_UI.agentProverCommand">
      </handler>
      <handler
            class="eventb_agent_ui.handlers.NewModelHandler"
            commandId="EventB_Agent_UI.newModelCommand">
      </handler>
      <handler
            class="eventb_agent_ui.evaluation.EvaluationHandler"
            commandId="EventB_Agent_UI.evaluate">
      </handler>
   </extension>
   <extension
         point="org.eclipse.ui.menus">
      <menuContribution
            allPopups="false"
            locationURI="menu:org.eclipse.ui.main.menu">
         <menu
               id="EventB_Agent_UI.agentMenu"
               label="Event-B Agent">
            <command
                  commandId="EventB_Agent_UI.newModelCommand"
                  label="Event-B Model Synthesis"
                  style="push">
            </command>
            <command
                  commandId="EventB_Agent_UI.agentProverCommand"
                  label="Agent Prover"
                  style="push">
            </command>
            <command
                  commandId="EventB_Agent_UI.evaluate"
                  label="Evaluation"
                  style="push">
            </command>
         </menu>
      </menuContribution>
   </extension>
</plugin>
