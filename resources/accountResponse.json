{
	"context": {
		"SETS": [
			"USERNAME_SET",
			"PASSWORD_SET"
		],
		"AXIOMS": [
			{
				"predicate": "∀u·(u ∈ USERNAME_SET ⇒ ∃p·(p ∈ PASSWORD_SET ∧ USER_PASSWORD(u) = p))",
				"label_name": "Unique_Username"
			}
		],
		"CONTEXT": "UserAccountContext",
		"EXTENDS": [
			"CryptographicHash"
		],
		"CONSTANTS": [
			"HASH_FUNCTION"
		]
	},
	"machine": {
		"SEES": [
			"UserAccountContext"
		],
		"EVENTS": [
			{
				"ANY": [
					"username",
					"password"
				],
				"THEN": [
					{
						"assignment": "USER_PASSWORD(username) := HASH_FUNCTION(password)",
						"label_name": "Store_Hashed_Password"
					}
				],
				"WITH": [
					{
						"predicate": "username ∈ USERNAME_SET",
						"label_name": "Valid_Username"
					},
					{
						"predicate": "password ∈ PASSWORD_SET",
						"label_name": "Valid_Password"
					}
				],
				"WHERE": [
					{
						"predicate": "HASH_FUNCTION(password) = USER_PASSWORD(username)",
						"label_name": "Match_Hash"
					}
				],
				"REFINES": [
					"AccountManagement"
				],
				"event_name": "CreateAccount"
			},
			{
				"ANY": [
					"username",
					"password"
				],
				"THEN": [
					{
						"assignment": "currentUser := username",
						"label_name": "Set_Current_User"
					}
				],
				"WITH": [
					{
						"predicate": "username ∈ USERNAME_SET",
						"label_name": "Valid_Username"
					},
					{
						"predicate": "HASH_FUNCTION(password) = USER_PASSWORD(username)",
						"label_name": "Correct_Password"
					}
				],
				"WHERE": [
					{
						"predicate": "currentUser = username",
						"label_name": "User_Logged_In"
					}
				],
				"REFINES": [
					"AccountManagement"
				],
				"event_name": "Login"
			},
			{
				"ANY": [
					"username"
				],
				"THEN": [
					{
						"assignment": "currentUser := NULL",
						"label_name": "Clear_Current_User"
					}
				],
				"WITH": [
					{
						"predicate": "currentUser = username",
						"label_name": "User_Logged_In"
					}
				],
				"WHERE": [],
				"REFINES": [
					"AccountManagement"
				],
				"event_name": "Logout"
			}
		],
		"MACHINE": "UserAccountMachine",
		"REFINES": [
			"UserAccountMachine"
		],
		"VARIANTS": [
			{
				"predicate": "number_of_Accounts ≤ max_Accounts",
				"label_name": "Account_Limit"
			}
		],
		"VARIABLES": [
			"USER_PASSWORD",
			"currentUser",
			"number_of_Accounts"
		],
		"INVARIANTS": [
			{
				"predicate": "∀u·(u ∈ USERNAME_SET ⇒ USER_PASSWORD(u) ∈ PASSWORD_SET)",
				"label_name": "Password_Present"
			},
			{
				"predicate": "number_of_Accounts = |USERNAME_SET|",
				"label_name": "Accounts_Count"
			}
		],
		"INITIALISATION": {
			"THEN": [
				{
					"assignment": "currentUser := NULL",
					"label_name": "Init_User"
				},
				{
					"assignment": "number_of_Accounts := 0",
					"label_name": "Init_Account_Count"
				}
			]
		}
	}
}