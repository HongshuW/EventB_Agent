						"label_name": "act2"
					},
					{
						"assignment": "cart := (cart(p) = 0) => cart \\setminus {p} | cart",
						"label_name": "act3"
					}
				],
				"REFINES": [],
				"ANY": [
					"p"
				],
				"WHERE": [
