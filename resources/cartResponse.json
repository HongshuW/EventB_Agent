{
	"context": {
		"EXTENDS": [],
		"CONSTANTS": [
			"store"
		],
		"AXIOMS": [
			{
				"predicate": "store.products ≠ ∅",
				"label_name": "StoreHasProducts"
			},
			{
				"predicate": "∀ product · (product ∈ store.products ⇒ store[product] ≥ 0)",
				"label_name": "NonNegativeStock"
			}
		],
		"SETS": [
			"Quantity",
			"Product"
		],
		"CONTEXT": "Shopping_Cart_Context"
	},
	"machine": {
		"EVENTS": [
			{
				"event_name": "Add_Product",
				"THEN": [
					{
						"assignment": "cart := cart + {product := quantity}",
						"label_name": "AddProductToCart"
					},
					{
						"assignment": "store := store - {product := quantity}",
						"label_name": "ReduceStoreQuantity"
					}
				],
				"REFINES": [
					"Check_Product_Exists",
					"Check_Stock_Availability"
				],
				"ANY": [
					"product",
					"quantity"
				],
				"WHERE": [
					{
						"predicate": "product ∈ store.products",
						"label_name": "ProductExists"
					},
					{
						"predicate": "quantity ≤ store[product]",
						"label_name": "StockAvailable"
					}
				],
				"WITH": [
					{
						"predicate": "store[product] := store[product] - quantity",
						"label_name": "UpdateStoreQuantity"
					}
				]
			},
			{
				"event_name": "Remove_Product",
				"THEN": [
					{
						"assignment": "cart := cart - {product}",
						"label_name": "RemoveProductFromCart"
					},
					{
						"assignment": "store := store + {product := cart[product]}",
						"label_name": "UpdateStoreAfterRemoval"
					}
				],
				"REFINES": [],
				"ANY": [
					"product"
				],
				"WHERE": [
					{
						"predicate": "product ∈ cart",
						"label_name": "ProductInCart"
					}
				],
				"WITH": []
			},
			{
				"event_name": "Consult_Cart",
				"THEN": [
					{
						"assignment": "products_list := cart",
						"label_name": "ShowCartProducts"
					}
				],
				"REFINES": [],
				"ANY": [],
				"WHERE": [],
				"WITH": []
			},
			{
				"event_name": "Reduce_Quantity",
				"THEN": [
					{
						"assignment": "cart[product] := cart[product] - 1",
						"label_name": "ReduceProductQuantityInCart"
					},
					{
						"assignment": "store := store + 1",
						"label_name": "UpdateStoreAfterReduction"
					}
				],
				"REFINES": [],
				"ANY": [
					"product"
				],
				"WHERE": [
					{
						"predicate": "product ∈ cart",
						"label_name": "ProductInCart"
					},
					{
						"predicate": "cart[product] > 0",
						"label_name": "PositiveQuantity"
					},
					{
						"predicate": "product ∈ store.products",
						"label_name": "ProductExistsInStore"
					}
				],
				"WITH": [
					{
						"predicate": "IF cart[product] = 0 THEN cart := cart - {product} END",
						"label_name": "RemoveFromCartIfZero"
					}
				]
			}
		],
		"VARIANTS": [],
		"INVARIANTS": [
			{
				"predicate": "∀ product · (product ∈ cart ⇒ product ∈ store.products)",
				"label_name": "ProductInCartMustExist"
			},
			{
				"predicate": "∀ product · (product ∈ cart ⇒ cart[product] > 0)",
				"label_name": "PositiveQuantityInCart"
			}
		],
		"SEES": [
			"Store"
		],
		"VARIABLES": [
			"cart"
		],
		"MACHINE": "Shopping_Cart",
		"INITIALISATION": {
			"THEN": [
				{
					"assignment": "cart := ∅",
					"label_name": "InitializeCart"
				},
				{
					"assignment": "store := ∅",
					"label_name": "InitializeStore"
				}
			]
		},
		"REFINES": []
	}
}