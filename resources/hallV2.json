{
	"context": {
		"EXTENDS": [],
		"CONSTANTS": [
			"DATES",
			"ARTISTS",
			"NAT_1"
		],
		"AXIOMS": [
			{
				"predicate": "DATES \\neq \\emptyset",
				"label_name": "nonempty_dates"
			},
			{
				"predicate": "ARTISTS \\neq \\emptyset",
				"label_name": "nonempty_artists"
			},
			{
				"predicate": "NAT_1 = \\{n \\in NAT \\mid n > 0\\}",
				"label_name": "positive_naturals"
			}
		],
		"SETS": [],
		"CONTEXT": "Concerts_ctx"
	},
	"machine": {
		"EVENTS": [
			{
				"event_name": "schedule_concert",
				"THEN": [
					{
						"assignment": "schedule(date) := artist;",
						"label_name": "assign_schedule"
					},
					{
						"assignment": "ticket_sales(artist) := 0;",
						"label_name": "initialize_tickets"
					}
				],
				"REFINES": [],
				"ANY": [
					"date",
					"artist"
				],
				"WHERE": [
					{
						"predicate": "date \\in DATES \\wedge artist \\in ARTISTS \\wedge date \\notin dom(schedule)",
						"label_name": "date_artist_valid"
					}
				],
				"WITH": []
			},
			{
				"event_name": "sell_tickets",
				"THEN": [
					{
						"assignment": "ticket_sales(schedule(date)) := ticket_sales(schedule(date)) + ntickets;",
						"label_name": "increment_tickets"
					}
				],
				"REFINES": [],
				"ANY": [
					"date",
					"ntickets"
				],
				"WHERE": [
					{
						"predicate": "date \\in DATES \\wedge ntickets \\in NAT_1 \\wedge date \\in dom(schedule)",
						"label_name": "valid_ticket_sale"
					}
				],
				"WITH": []
			},
			{
				"event_name": "retrieve_dates",
				"THEN": [
					{
						"assignment": "r := \\{d \\mid d \\in DATES \\land schedule(d) = artist\\}",
						"label_name": "assign_result"
					}
				],
				"REFINES": [],
				"ANY": [
					"artist",
					"r"
				],
				"WHERE": [
					{
						"predicate": "artist \\in ARTISTS",
						"label_name": "artist_exists"
					}
				],
				"WITH": []
			}
		],
		"VARIANTS": [],
		"INVARIANTS": [
			{
				"predicate": "schedule \\in DATES \\pfun ARTISTS",
				"label_name": "schedule_is_partial_function"
			},
			{
				"predicate": "ticket_sales \\in ARTISTS \\pfun NAT",
				"label_name": "tickets_sales_total_type"
			}
		],
		"SEES": [
			"Concerts_ctx"
		],
		"VARIABLES": [
			"schedule",
			"ticket_sales"
		],
		"MACHINE": "Concerts_mch",
		"REFINES": []
	}
